# Quiksheets environment variables

# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Quiksheets
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# AI controls
AI_RATE_LIMIT_PER_USER=50
AI_TIMEOUT_MS=30000

# Engine selection (fortune | univer)
NEXT_PUBLIC_ENGINE=fortune

# Feature flags (off by default)
NEXT_PUBLIC_FF_PIVOT=false
NEXT_PUBLIC_FF_DASHBOARDS=false
NEXT_PUBLIC_FF_MACROS=false
NEXT_PUBLIC_FF_CONNECTORS=false
NEXT_PUBLIC_FF_ROW_RLS=false
NEXT_PUBLIC_FF_FORECAST=false
NEXT_PUBLIC_REALTIME_CRDT=false
NEXT_PUBLIC_FEATURE_UNIVER_PRO=false

# Integrations
EMAIL_PROVIDER=mock
SLACK_PROVIDER=mock
TEAMS_PROVIDER=mock
WHATSAPP_PROVIDER=mock
TASK_PROVIDER=mock
