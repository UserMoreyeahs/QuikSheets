# Anti-hallucination: production hides ribbon buttons whose handler
# is a `ribbonStub('Foo')`. Visible buttons must do something real.
# Set to 'false' (or unset) in dev so we can still see what's missing.
NEXT_PUBLIC_HIDE_RIBBON_STUBS=true
